# Azure OpenAI
AZURE_OPENAI_API_KEY= API_KEY
AZURE_OPENAI_ENDPOINT= ENDPOINT
API_VERSION= VERSION
AZURE_OPENAI_DEPLOYMENT= CHAT_DEPLOYMENT
AZURE_OPENAI_EMBEDDING= TEXT_EMBEDDING

# RAG - Semantic Chunking Settings
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP_SENTENCES=2
RAG_TOP_K=5
RAG_USE_QUERY_EXPANSION=true

# Vector DB
CHROMA_PERSIST_DIR=./chroma_db

# Agent
MAX_TOOL_ITERATIONS=3
LLM_TEMPERATURE=SET_TEMPERATURE

# Logging
LOG_LEVEL=INFO